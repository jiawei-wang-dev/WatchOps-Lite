# Copy these values into your shell environment as needed.
# The application does not automatically load .env files.

WATCHOPS_CONFIG_FILE=configs/config.json
WATCHOPS_SERVER_ADDRESS=:8080
WATCHOPS_SERVER_READ_HEADER_TIMEOUT=5s
WATCHOPS_SERVER_READ_TIMEOUT=15s
WATCHOPS_SERVER_WRITE_TIMEOUT=15s
WATCHOPS_SERVER_IDLE_TIMEOUT=60s
WATCHOPS_SERVER_SHUTDOWN_TIMEOUT=10s
WATCHOPS_LOG_LEVEL=info
WATCHOPS_REDIS_ADDRESS=localhost:6379
WATCHOPS_REDIS_USERNAME=
WATCHOPS_REDIS_PASSWORD=
WATCHOPS_REDIS_DB=0
WATCHOPS_REDIS_DIAL_TIMEOUT=2s
WATCHOPS_REDIS_READ_TIMEOUT=2s
WATCHOPS_REDIS_WRITE_TIMEOUT=2s
WATCHOPS_SESSION_RECENT_WINDOW_SIZE=12
WATCHOPS_SESSION_SUMMARY_THRESHOLD=12
WATCHOPS_SESSION_TTL=24h
WATCHOPS_SUMMARY_MODE=deterministic
WATCHOPS_SUMMARY_PROMPT_VERSION=session_summary_v1
WATCHOPS_SUMMARY_TIMEOUT=10s
WATCHOPS_SUMMARY_FALLBACK_TO_DETERMINISTIC=true
WATCHOPS_ELASTICSEARCH_ENABLED=false
WATCHOPS_ELASTICSEARCH_ADDRESSES=http://localhost:9200
WATCHOPS_ELASTICSEARCH_USERNAME=
WATCHOPS_ELASTICSEARCH_PASSWORD=
WATCHOPS_ELASTICSEARCH_KNOWLEDGE_INDEX=watchops_knowledge
WATCHOPS_ELASTICSEARCH_REQUEST_TIMEOUT=3s
WATCHOPS_KNOWLEDGE_CHUNK_MAX_SIZE=1200
WATCHOPS_KNOWLEDGE_RETRIEVAL_MODE=bm25
WATCHOPS_KNOWLEDGE_BM25_TOP_K=10
WATCHOPS_KNOWLEDGE_VECTOR_TOP_K=10
WATCHOPS_KNOWLEDGE_FINAL_TOP_K=5
WATCHOPS_KNOWLEDGE_RRF_K=60
WATCHOPS_KNOWLEDGE_FALLBACK_TO_BM25=true
WATCHOPS_EMBEDDING_ENABLED=false
WATCHOPS_EMBEDDING_PROVIDER=openai_compatible
WATCHOPS_EMBEDDING_BASE_URL=
WATCHOPS_EMBEDDING_API_KEY_ENV=WATCHOPS_EMBEDDING_API_KEY
WATCHOPS_EMBEDDING_API_KEY=
WATCHOPS_EMBEDDING_MODEL=
WATCHOPS_EMBEDDING_DIMENSION=1536
WATCHOPS_EMBEDDING_REQUEST_TIMEOUT=10s
WATCHOPS_LOGS_BACKEND=mock
WATCHOPS_LOGS_INDEX=watchops_logs
WATCHOPS_LOGS_FALLBACK_TO_MOCK=true
WATCHOPS_LOGS_DEFAULT_LIMIT=20
WATCHOPS_METRICS_BACKEND=mock
WATCHOPS_METRICS_BASE_URL=http://localhost:9090
WATCHOPS_METRICS_FALLBACK_TO_MOCK=true
WATCHOPS_METRICS_DEFAULT_STEP=30s
WATCHOPS_METRICS_REQUEST_TIMEOUT=3s
WATCHOPS_METRICS_QUERY_CHECKOUT_ERROR_RATE=watchops_checkout_error_rate
WATCHOPS_METRICS_QUERY_CHECKOUT_P95_LATENCY=watchops_checkout_p95_latency_seconds
WATCHOPS_METRICS_QUERY_CHECKOUT_TIMEOUT_TOTAL=watchops_checkout_timeout_total
WATCHOPS_METRICS_QUERY_PAYMENT_DEPENDENCY_LATENCY=watchops_payment_dependency_latency_seconds
WATCHOPS_TRACES_BACKEND=mock
WATCHOPS_TRACES_BASE_URL=http://localhost:16686
WATCHOPS_TRACES_FALLBACK_TO_MOCK=true
WATCHOPS_TRACES_DEFAULT_LIMIT=10
WATCHOPS_TRACES_REQUEST_TIMEOUT=3s
WATCHOPS_TRACES_DEFAULT_SERVICE=watchops-lite
WATCHOPS_MYSQL_ENABLED=false
WATCHOPS_MYSQL_DSN=watchops:watchops@tcp(localhost:3306)/watchops_lite?parseTime=true
WATCHOPS_MYSQL_MAX_OPEN_CONNS=10
WATCHOPS_MYSQL_MAX_IDLE_CONNS=5
WATCHOPS_MYSQL_CONN_MAX_LIFETIME=30m
WATCHOPS_MYSQL_REQUEST_TIMEOUT=3s
WATCHOPS_AGENT_MODE=deterministic
WATCHOPS_AGENT_MAX_ITERATIONS=6
WATCHOPS_AGENT_TIMEOUT=30s
WATCHOPS_AGENT_PROMPT_VERSION=watchops_agent_v1
WATCHOPS_LLM_ENABLED=false
WATCHOPS_LLM_PROVIDER=openai_compatible
WATCHOPS_LLM_BASE_URL=
WATCHOPS_LLM_API_KEY_ENV=WATCHOPS_LLM_API_KEY
WATCHOPS_LLM_API_KEY=
WATCHOPS_LLM_MODEL=
WATCHOPS_LLM_TEMPERATURE=0.2
WATCHOPS_LLM_REQUEST_TIMEOUT=30s
WATCHOPS_TELEMETRY_ENABLED=false
WATCHOPS_TELEMETRY_SERVICE_NAME=watchops-lite
WATCHOPS_TELEMETRY_ENVIRONMENT=local
WATCHOPS_TELEMETRY_OTLP_ENDPOINT=localhost:4317
WATCHOPS_TELEMETRY_INSECURE=true
WATCHOPS_TELEMETRY_SAMPLE_RATIO=1.0
WATCHOPS_TELEMETRY_EXPORT_TIMEOUT=3s
