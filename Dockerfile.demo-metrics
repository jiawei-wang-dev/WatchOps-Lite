FROM golang:1.23-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
COPY cmd/demo-metrics ./cmd/demo-metrics
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /demo-metrics ./cmd/demo-metrics

FROM scratch

COPY --from=build /demo-metrics /usr/local/bin/demo-metrics
USER 65532:65532
EXPOSE 9108
ENTRYPOINT ["/usr/local/bin/demo-metrics"]
