    "request_timeout": "3s"
  },
  "knowledge": {
    "chunk_max_size": 1200
  },
  "mysql": {
    "enabled": false,
    "dsn": "watchops:watchops@tcp(localhost:3306)/watchops_lite?parseTime=true",
    "max_open_conns": 10,
    "max_idle_conns": 5,
    "conn_max_lifetime": "30m",
    "request_timeout": "3s"
  },
  "telemetry": {
    "enabled": false,
    "service_name": "watchops-lite",
    "otlp_endpoint": "http://localhost:4318",
    "sample_ratio": 1.0
  }
